{
    "version":  "1.0.0",
    "private":  true,
    "main":  "expo-router/entry",
    "scripts":  {
                    "start":  "expo start",
                    "android":  "expo start --android",
                    "ios":  "expo start --ios",
                    "web":  "expo start --web",
                    "build:dev":  "eas build --profile development --platform all",
                    "build:preview":  "eas build --profile preview --platform all",
                    "build:prod":  "eas build --profile production --platform all",
                    "submit:android":  "eas submit --platform android --profile production",
                    "submit:ios":  "eas submit --platform ios --profile production",
                    "lint":  "eslint .",
                    "test":  "jest",
                    "deploy:phone":  "powershell -ExecutionPolicy Bypass -File ./deploy-to-phone.ps1",
                    "deploy:phone:fast":  "powershell -ExecutionPolicy Bypass -File ./deploy-to-phone.ps1 -SkipBundle",
                    "deploy:phone:clean":  "powershell -ExecutionPolicy Bypass -File ./deploy-to-phone.ps1 -Clean"
                },
    "dependencies":  {
                         "@react-native-async-storage/async-storage":  "1.23.1",
                         "@react-navigation/native":  "^7.0.0",
                         "expo":  "~52.0.0",
                         "expo-camera":  "~16.0.18",
                         "expo-clipboard":  "~7.0.1",
                         "expo-font":  "~13.0.0",
                         "expo-haptics":  "~14.0.0",
                         "expo-linear-gradient":  "~14.0.2",
                         "expo-localization":  "~16.0.0",
                         "expo-router":  "~4.0.0",
                         "expo-speech":  "~13.0.0",
                         "expo-splash-screen":  "~0.29.0",
                         "expo-status-bar":  "~2.0.0",
                         "expo-web-browser":  "~14.0.2",
                         "react":  "18.3.1",
                         "react-native":  "0.76.7",
                         "react-native-gesture-handler":  "~2.21.0",
                         "react-native-reanimated":  "~3.16.0",
                         "react-native-safe-area-context":  "~4.14.0",
                         "react-native-screens":  "~4.4.0",
                         "react-native-webrtc":  "^124.0.7",
                         "react-native-webview":  "13.12.5",
                         "socket.io-client":  "^4.7.0"
                     },
    "devDependencies":  {
                            "@babel/core":  "^7.25.0",
                            "@types/react":  "~18.3.0",
                            "eslint":  "^9.0.0",
                            "jest":  "^29.7.0",
                            "jest-expo":  "~52.0.0",
                            "typescript":  "~5.6.0"
                        }
}
