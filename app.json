{
  "expo": {
    "name": "Qui Est-Ce?",
    "slug": "quiestce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "scheme": "sallycards",
    "ios": {
      "bundleIdentifier": "com.sallycards.quiestce",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Quiestce utilise votre position pour la carte des hkim."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAa1lBSroSXA-Om4mio84-SWAcmzQgYv8w"
      }
    },
    "android": {
      "package": "com.sallycards.quiestce",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAa1lBSroSXA-Om4mio84-SWAcmzQgYv8w"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Quiestce utilise votre position pour la carte des hkim."
        }
      ]
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "sallycards-quiestce"
      },
      "usesCleartextTraffic": true
    }
  }
}
